{
    "name": "ddd-erp/app",
    "type": "project",
    "description": "DDD ERP systém — Symfony 8 + CQRS + Vertical Slice Architecture",
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "symfony/framework-bundle": "^7.2",
        "symfony/dotenv": "^7.2",
        "symfony/runtime": "^7.2",
        "symfony/messenger": "^7.2",
        "symfony/security-bundle": "^7.2",
        "symfony/uid": "^7.2",
        "doctrine/orm": "^3.0",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "nelmio/api-doc-bundle": "^4.27"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^7.2",
        "symfony/http-client": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^7.2"
        }
    }
}
