{
    "name": "ddd-erp/audit",
    "type": "library",
    "description": "Audit log — cross-cutting event listener bounded context",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {"type": "path", "url": "../shared-kernel"},
        {"type": "path", "url": "../crm"},
        {"type": "path", "url": "../identity"}
    ],
    "require": {
        "php": "^8.4",
        "ddd-erp/shared-kernel": "*",
        "ddd-erp/crm": "*",
        "ddd-erp/identity": "*",
        "doctrine/orm": "^3.0",
        "doctrine/dbal": "^4.0",
        "symfony/messenger": "^7.2",
        "symfony/security-bundle": "^7.2",
        "symfony/uid": "^7.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "Audit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Audit\\Tests\\": "tests/"
        }
    }
}
