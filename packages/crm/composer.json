{
    "name": "ddd-erp/crm",
    "type": "library",
    "description": "CRM doménový package — Contacts, SalesPipeline, Activities Bounded Contexts",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../shared-kernel"
        }
    ],
    "require": {
        "php": "^8.4",
        "ddd-erp/shared-kernel": "*",
        "doctrine/orm": "^3.0",
        "doctrine/dbal": "^4.0",
        "symfony/security-core": "^7.2",
        "symfony/uid": "^7.2",
        "symfony/messenger": "^7.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "Crm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Crm\\Tests\\": "tests/"
        }
    }
}
