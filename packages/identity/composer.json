{
    "name": "ddd-erp/identity",
    "type": "library",
    "description": "Identity & Access Bounded Context — Users, Roles, JWT Auth",
    "require": {
        "php": "^8.4",
        "ddd-erp/shared-kernel": "*",
        "doctrine/orm": "^3.0",
        "doctrine/doctrine-bundle": "^2.0",
        "symfony/security-bundle": "^7.0",
        "symfony/uid": "^7.0",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Identity\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Identity\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Role/Application/TestDoubles.php",
            "tests/User/Application/TestDoubles.php",
            "tests/Auth/Application/TestDoubles.php"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {"type": "path", "url": "../../packages/shared-kernel", "options": {"symlink": true}}
    ]
}
