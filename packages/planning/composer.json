{
    "name": "ddd-erp/planning",
    "type": "library",
    "description": "Planning bounded context — orders, phases, worker allocations",
    "require": {
        "php": "^8.4",
        "ddd-erp/shared-kernel": "*",
        "doctrine/orm": "^3.0",
        "doctrine/doctrine-bundle": "^2.0",
        "symfony/security-bundle": "^7.0",
        "symfony/uid": "^7.0",
        "ddd-erp/sales": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Planning\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Planning\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {"type": "path", "url": "../../packages/shared-kernel", "options": {"symlink": true}},
        {"type": "path", "url": "../sales", "options": {"symlink": true}}
    ]
}
