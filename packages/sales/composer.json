{
    "name": "ddd-erp/sales",
    "type": "library",
    "description": "Sales BC — Inquiries and Quotes",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {"type": "path", "url": "../shared-kernel", "options": {"symlink": true}}
    ],
    "require": {
        "php": "^8.4",
        "ddd-erp/shared-kernel": "*",
        "doctrine/dbal": "^4.0",
        "doctrine/orm": "^3.0",
        "symfony/uid": "^7.2",
        "symfony/messenger": "^7.2",
        "symfony/security-core": "^7.2",
        "dompdf/dompdf": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {"Sales\\": "src/"}
    },
    "autoload-dev": {
        "psr-4": {"Sales\\Tests\\": "tests/"}
    }
}
