{
    "name": "ddd-erp/shared-kernel",
    "type": "library",
    "description": "Shared Kernel — DDD base classes, Bus interfaces, Messenger implementations",
    "require": {
        "php": "^8.4",
        "symfony/messenger": "^7.2",
        "symfony/http-kernel": "^7.2",
        "symfony/event-dispatcher": "^7.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "SharedKernel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SharedKernel\\Tests\\": "tests/"
        }
    }
}
